# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
#
# IMPORTANT — if using Neon (or any serverless Postgres with connection pooling):
# Use the POOLED connection string (hostname contains "-pooler"), NOT the direct one.
# Neon's dashboard shows both — copy the one labeled "Pooled connection".
#   Direct (DON'T use for the app):  ep-xxx.us-east-1.aws.neon.tech
#   Pooled (USE this for the app):   ep-xxx-pooler.us-east-1.aws.neon.tech
#
# The direct endpoint has a very small connection ceiling and will throw
# "Timed out fetching a new connection from the connection pool" almost
# immediately under Next.js dev mode, which compiles routes in parallel and
# can briefly open several DB connections at once.
#
# You can also tune Prisma's own pool size via query params if needed:
#   ?connection_limit=10&pool_timeout=30
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&connection_limit=10&pool_timeout=30"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="smartclinic_jwt_secret_change_in_prod"

# ─── File storage (offer images) ──────────────────────────────────────────────
# Offer images upload to Vercel Blob storage instead of the local filesystem.
# This is required — Vercel's filesystem is ephemeral and any file written
# with fs.writeFile() is lost on every redeploy or cold start.
#
# To get this token:
#   1. In your Vercel dashboard, go to your project → Storage → Create Database
#   2. Choose "Blob" → create a store (any name, e.g. "smartclinic-images")
#   3. Vercel automatically injects BLOB_READ_WRITE_TOKEN into your project's
#      environment variables — you usually don't need to set this manually
#      in production. For LOCAL development, run `vercel env pull .env.local`
#      after creating the store to pull this token down automatically.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_verify_token

# ─── Google Calendar API ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth2callback
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Instagram Messaging API ──────────────────────────────────────────────────
# Get from Meta Developer Console → Your App → Instagram → Messaging
INSTAGRAM_TOKEN=your_instagram_page_access_token
INSTAGRAM_VERIFY_TOKEN=your_instagram_verify_token
